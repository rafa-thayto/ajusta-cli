  "license": "MIT",
  "homepage": "https://ajustacv.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafa-thayto/ajusta-cli.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "mime-types": "^2.1.35",
    "ora": "^8.2.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.15.3",
    "@types/qrcode-terminal": "^0.12.2",
