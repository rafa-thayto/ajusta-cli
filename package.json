{
  "name": "ajusta",
  "version": "1.8.0",
  "description": "CLI para análise ATS e otimização de currículos — by AjustaCV",
  "type": "module",
  "bin": {
    "ajusta": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "release": "npm version minor && npm publish && git push origin main --tags"
